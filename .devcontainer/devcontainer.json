{
  "name": "Expo React Native Widescreen Workspace",
  "image": "://microsoft.com",
  
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "expo.vscode-expo-tools",
        "amiralis.unistyles-extension"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "tailwindCSS.experimental.classRegex": [
          ["className=\"([^\"]*)\"", "([a-zA-Z0-9\\s_-:]+)"]
        ]
      }
    }
  },

  "forwardPorts": [8081],

  "portsAttributes": {
    "8081": {
      "label": "Metro Bundler Server",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },

  "postCreateCommand": "npm install -g eas-cli && npm install",
  "remoteUser": "node",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:1": {
      "installZsh": true,
      "configureZshAsDefaultShell": true
    }
  }
}
